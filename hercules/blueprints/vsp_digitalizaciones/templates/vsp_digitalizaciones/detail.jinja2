{% extends 'layouts/app.jinja2' %}
{% import 'macros/detail.jinja2' as detail %}
{% import 'macros/modals.jinja2' as modals %}
{% import 'macros/topbar.jinja2' as topbar %}

{% set title = 'Digitalización ' + vsp_digitalizacion.expediente + ' del ' + vsp_digitalizacion.autoridad.clave %}

{% block title %}{{ title }}{% endblock %}

{% block topbar_actions %}
    {% call topbar.page_buttons('Digitalización ' + vsp_digitalizacion.expediente) %}
        {{ topbar.button_previous('Digitalizaciones', url_for('vsp_digitalizaciones.list_active')) }}
        {% if current_user.can_edit('VSP DIGITALIZACIONES') %}
            {{ topbar.button_edit('Editar', url_for('vsp_digitalizaciones.edit', vsp_digitalizacion_id=vsp_digitalizacion.id)) }}
        {% endif %}
        {% if current_user.can_admin('VSP DIGITALIZACIONES') %}
            {% if vsp_digitalizacion.estatus == 'A' %}{{ topbar.button_delete('Eliminar', url_for('vsp_digitalizaciones.delete', vsp_digitalizacion_id=vsp_digitalizacion.id)) }}{% endif %}
            {% if vsp_digitalizacion.estatus == 'B' %}{{ topbar.button_recover('Recuperar', url_for('vsp_digitalizaciones.recover', vsp_digitalizacion_id=vsp_digitalizacion.id)) }}{% endif %}
        {% endif %}
    {% endcall %}
{% endblock %}

{% block content %}
    {% call detail.card(estatus=vsp_digitalizacion.estatus) %}
        {{ detail.label_value_big('Expediente', vsp_digitalizacion.expediente) }}
        {{ detail.label_value('Descripción', vsp_digitalizacion.descripcion) }}
        {{ detail.label_value('Observaciones', vsp_digitalizacion.observaciones) }}
        {{ detail.label_value('Creado', moment(vsp_digitalizacion.creado, local=False).format('DD MMM YYYY HH:mm')) }}
    {% endcall %}
    {% call detail.card() %}
        <object data="{{ url_for('vsp_digitalizacion.view_file_pdf', vsp_digitalizacion_id=vsp_digitalizacion.id) }}" type="application/pdf" width="100%" height="600px">
            <p class="mb-0">El navegador no puede mostrar el archivo PDF o no existe en el depósito.</p>
        </object>
    {% endcall %}
{% endblock %}

{% block custom_javascript %}
    {% if current_user.can_admin('VSP DIGITALIZACIONES') %}
        {% if vsp_digitalizacion.estatus == 'A' %}{{ modals.custom_javascript_delete('Eliminar', '¿Eliminar la ' + title + '?') }}{% endif %}
        {% if vsp_digitalizacion.estatus == 'B' %}{{ modals.custom_javascript_recover('Recuperar', '¿Recuperar la ' + title + '?') }}{% endif %}
    {% endif %}
{% endblock %}
