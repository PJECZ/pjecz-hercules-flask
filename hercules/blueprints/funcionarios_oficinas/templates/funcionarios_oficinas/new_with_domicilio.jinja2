{% extends 'layouts/app.jinja2' %}
{% import 'macros/form.jinja2' as f with context %}
{% import 'macros/topbar.jinja2' as topbar %}

{% block title %}Nuevo Oficinas con Domicilio{% endblock %}

{% block topbar_actions %}
{{ topbar.page('Nuevo Oficinas con Domicilio') }}
{% endblock %}

{% block content %}
    {% call f.card() %}
        {% set form_kwargs = {'funcionario_id': funcionario.id} %}
        {% call f.form_tag('funcionarios_oficinas.news_with_domicilio_with_funcionario', fid='funcionario_oficina_form', **form_kwargs) %}
            {% call f.form_group(form.funcionario_nombre) %}{% endcall %}
            {% call f.form_group(form.funcionario_puesto) %}{% endcall %}
            {% call f.form_group(form.funcionario_email) %}{% endcall %}
            {% call f.form_group(form.domicilio) %}{% endcall %}
            {% call f.form_group(form.guardar) %}{% endcall %}
        {% endcall %}
    {% endcall %}
{% endblock %}

{% block custom_javascript %}
{% endblock %}
